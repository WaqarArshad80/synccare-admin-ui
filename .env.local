# Same-origin prefix the browser calls. Next.js rewrites /backend/* to the real
# API (see API_PROXY_TARGET) so requests are same-origin and avoid CORS.
NEXT_PUBLIC_API_BASE_URL=/backend

# Where the Next server forwards /backend/* requests. Server-side only.
API_PROXY_TARGET=http://localhost:4080
#API_PROXY_TARGET=https://pcc.syncaresystems.com
